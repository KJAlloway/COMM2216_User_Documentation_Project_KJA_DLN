<?xml version="1.0" encoding="UTF-8"?>
<!--
    CST IntelliJ IDEA Keymap
    Based on the default Windows keymap.

    Changes from default:
    - Ctrl+L added as an additional shortcut for Reformat Code
      (Ctrl+Alt+L is preserved alongside it)

    All other shortcuts are unchanged from the IntelliJ IDEA defaults.

    Import via:
    File > Settings > Keymap > gear icon > Import Keymap
-->
<keymap version="1" name="CST_Keymap" parent="$default">

    <!-- ============================================================
         REFORMAT CODE
         Ctrl+L added as a faster alternative to the default Ctrl+Alt+L.
         Both shortcuts are active — neither removes the other.
         Useful on systems where Ctrl+Alt+L conflicts with screen lock.
    ============================================================ -->
    <action id="ReformatCode">
        <keyboard-shortcut first-keystroke="ctrl L"/>
        <keyboard-shortcut first-keystroke="ctrl alt L"/>
    </action>

</keymap>
